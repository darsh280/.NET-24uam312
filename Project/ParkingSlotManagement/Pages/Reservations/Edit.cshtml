@page
@model ParkingSlotManagement.Pages.Reservations.Edit
@{
    ViewData["Title"] = "Edit";
}

<div class="container mt-4">
    <h2>Edit Reservation</h2>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success">@Model.SuccessMessage</div>
    }

    <form method="post">
        <!-- Hidden field for Id -->
        <input type="hidden" asp-for="Reservation.Id" />

        <div class="mb-3">
            <label class="form-label">Slot Id</label>
            <input asp-for="Reservation.SlotId" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Vehicle No</label>
            <input asp-for="Reservation.VehicleNo" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Time In</label>
            <input asp-for="Reservation.TimeIn" class="form-control" type="datetime-local" />
        </div>

        <div class="mb-3">
            <label class="form-label">Time Out</label>
            <input asp-for="Reservation.TimeOut" class="form-control" type="datetime-local" />
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-page="/Reservations/Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>